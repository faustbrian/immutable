{
    "name": "cline/immutable",
    "description": "Immutable object mutation utilities for PHP - create modified copies without changing originals",
    "license": "MIT",
    "keywords": [
        "php",
        "immutable",
        "mutation",
        "clone",
        "laravel"
    ],
    "authors": [
        {
            "name": "Brian Faust",
            "email": "brian@cline.sh"
        }
    ],
    "require": {
        "php": "^8.5.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "spatie/laravel-package-tools": "^1.93.0"
    },
    "require-dev": {
        "cline/coding-standard": "^1.7.0",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.9",
        "symfony/var-dumper": "^6.0 || ^7.4.6"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Cline\\Immutable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "aliases": {
                "Mutator": "Cline\\Immutable\\Facades\\Mutator"
            },
            "providers": [
                "Cline\\Immutable\\ImmutableServiceProvider"
            ]
        }
    },
    "scripts": {
        "lint": "vendor/bin/ecs check --fix",
        "refactor": "rector",
        "test": [
            "@test:lint",
            "@test:type-coverage",
            "@test:unit",
            "@test:types",
            "@test:refactor"
        ],
        "test:lint": "vendor/bin/ecs check",
        "test:refactor": "rector --dry-run",
        "test:type-coverage": "pest --parallel --min=80 --type-coverage",
        "test:types": "phpstan",
        "test:unit": "pest --parallel --min=80 --coverage"
    }
}
